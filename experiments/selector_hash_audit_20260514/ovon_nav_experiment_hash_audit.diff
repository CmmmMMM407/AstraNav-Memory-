+def _image_hash(image):
+    arr = np.asarray(image)
+    return hashlib.sha1(arr.tobytes()).hexdigest()[:16]
+
+
+def _pose_hash(state):
+    pos = [float(state.position[0]), float(state.position[1]), float(state.position[2])]
+    rot = [float(state.rotation.x), float(state.rotation.y), float(state.rotation.z), float(state.rotation.w)]
+    payload = json.dumps({'pos': pos, 'rot': rot}, sort_keys=True)
+    return hashlib.sha1(payload.encode('utf-8')).hexdigest()[:16]
+
+
+def _selection_fingerprint(indices, image_hashes, pose_hashes):
+    payload = json.dumps({'indices': indices, 'image_hashes': image_hashes, 'pose_hashes': pose_hashes}, sort_keys=True)
+    return hashlib.sha1(payload.encode('utf-8')).hexdigest()[:16]
